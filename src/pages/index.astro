---
import ThemeLayout from "../theme/layouts/ThemeLayout.astro";
import ThemeCard from "../theme/components/ThemeCard.astro";
import { Button } from "@/components/ui";
import { InvoiceTable, DialogComp as Dialog } from "@/components/";
---

<ThemeLayout
  title="My Shadcn Theme — Showcase"
  description="A stunning theme built with shadcn/ui, Astro, and GSAP animations"
>
  <div class="flex gap-4 h-full">
    <!-- Black theme -->
    <div
      class="dark flex-1 bg-background text-foreground flex items-center justify-center"
    >
      <Button client:load variant="glass" glowColor="blue">
        Glass Button
      </Button>

      <Dialog client:load />
    </div>

    <!-- White theme -->
    <div class="flex-1 bg-white h-full flex items-center justify-center">
      <div class="flex flex-col gap-4">
        <Button client:load variant="glass" glowColor="yellow">
          $179.900 <small>COP</small>
        </Button>

        <InvoiceTable client:load />
      </div>
    </div>
  </div>
</ThemeLayout>

<style></style>
